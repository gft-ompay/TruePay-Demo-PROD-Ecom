# TestMart — TruePay test storefront config.
# Copy to ".env" for LOCAL runs. On Render, set these as Environment variables
# in the dashboard instead (do NOT commit a real .env).

# TruePay Core API base URL. PRODUCTION (live) — real cards, real money.
TRUEPAY_BASE_URL=https://api.truepay.ompay.om

# Your sandbox merchant's API credentials
# (Admin Portal -> Merchants -> your account -> API Key / API Secret).
TRUEPAY_API_KEY=your_api_key_here
TRUEPAY_API_SECRET=your_api_secret_here

# Optional. This site's own public URL, used for the checkout return link.
# On Render this is auto-detected (RENDER_EXTERNAL_URL) — leave unset there.
# Set it only if you host somewhere that doesn't inject that variable.
# PUBLIC_URL=https://truepay-teststore.onrender.com

# Optional. Local dev port (ignored on Render, which injects PORT).
PORT=6012
